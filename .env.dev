# 백엔드 API URL (Next.js rewrites를 통해 프록시)
NEXT_PUBLIC_API_URL=/api/v1

# OAuth 콜백을 위한 백엔드 실제 URL (카카오 서버가 직접 호출하므로 절대 URL 필요)
# 개발 환경 (docker-compose.dev.yml): nginx 80포트 → backend 8080포트로 프록시
# 프로덕션: https://wheelfinder.deving.xyz/api

# OAuth 설정 - 각 provider별 Client ID (백엔드에서 처리하므로 Secret은 불필요)
# 네이버
NEXT_PUBLIC_NAVER_CLIENT_ID=your_naver_client_id

# 구글
